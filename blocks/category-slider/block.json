{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "golden-hive/category-slider",
    "version": "1.1.0",
    "title": "Category Slider",
    "category": "golden-hive",
    "icon": "category",
    "description": "Swiper.js category carousel with images - Shopify style.",
    "keywords": ["category", "collection", "slider", "carousel", "shopify", "swiper"],
    "textdomain": "golden-hive-blocks",
    "attributes": {
        "title": {
            "type": "string",
            "default": "Esplora le Categorie"
        },
        "categories": {
            "type": "array",
            "default": [
                { "name": "Sneakers", "image": "", "url": "#sneakers" },
                { "name": "Streetwear", "image": "", "url": "#streetwear" },
                { "name": "Accessori", "image": "", "url": "#accessori" },
                { "name": "Limited Edition", "image": "", "url": "#limited" }
            ]
        },
        "showNav": {
            "type": "boolean",
            "default": true
        },
        "showDots": {
            "type": "boolean",
            "default": false
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        },
        "loop": {
            "type": "boolean",
            "default": true
        },
        "imageRatio": {
            "type": "string",
            "default": "4 / 5"
        },
        "paddingTop": {
            "type": "number",
            "default": 40
        },
        "paddingBottom": {
            "type": "number",
            "default": 40
        }
    },
    "supports": {
        "align": ["wide", "full"],
        "html": false
    },
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
