{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "golden-hive/map-embed",
    "version": "1.0.0",
    "title": "Map Embed",
    "category": "golden-hive",
    "icon": "location",
    "description": "Mappa Google Maps integrata per mostrare la posizione del negozio.",
    "keywords": ["mappa", "google", "maps", "posizione", "negozio"],
    "textdomain": "golden-hive-blocks",
    "attributes": {
        "embedCode": {
            "type": "string",
            "default": "<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2819.1!2d9.6884327!3d45.0482437!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4780dd3b7d8a913b%3A0x26e569f7b44a6448!2sResellpiacenza!5e0!3m2!1sit!2sit!4v1\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>"
        },
        "height": {
            "type": "number",
            "default": 450
        },
        "borderRadius": {
            "type": "number",
            "default": 12
        }
    },
    "supports": {
        "align": ["wide", "full"],
        "html": false
    },
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
